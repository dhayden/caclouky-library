{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=CacloukyLibrary;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "https://caclouky.org",
    "Audience": "https://caclouky.org",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": ["http://localhost:4200", "https://caclouky.org"],
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY_FROM_AISTUDIO_GOOGLE_COM"
  },
  "SermonPdfs": {
    "StoragePath": "sermon-pdfs"
  }
}
